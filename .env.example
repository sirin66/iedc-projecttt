# ------------------------------------------------------------------------------
# IEDC RIT Event Platform - Environment Configuration Template
# ------------------------------------------------------------------------------
# Copy this file to '.env' and fill in your real production credentials.
# This file must NOT contain any real secrets and can be committed to Git.
# ------------------------------------------------------------------------------

# Admin Credentials
ADMIN_EMAIL=
ADMIN_PASSWORD=
GATE_PASSWORD_PRIMARY=
GATE_PASSWORD_SECONDARY=

# Firebase Configuration (Vite/Webpack environment variants)
# For Vite, prefix with VITE_ (e.g. VITE_FIREBASE_API_KEY).
# For Webpack/Node, use standard naming (e.g. FIREBASE_API_KEY).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Supabase Storage Configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

SUPABASE_URL=
SUPABASE_ANON_KEY=

# EmailJS Ticket Dispatch Configuration
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=

EMAILJS_PUBLIC_KEY=
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
